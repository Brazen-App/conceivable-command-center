generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  role          String    @default("team")
  inviteToken   String?   @unique
  inviteExpires DateTime?
  invitedBy     String?
  lastLoginAt   DateTime?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model DataRoomDocument {
  id          String   @id @default(cuid())
  folder      String
  title       String
  description String?
  url         String?
  fileName    String?
  fileUrl     String?
  fileSize    Int?
  mimeType    String?
  status      String   @default("missing")
  sortOrder   Int      @default(0)
  uploadedBy  String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  status    String   @default("green")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  alerts    Alert[]
  briefs    Brief[]
  metrics   Metric[]
  tasks     Task[]
}

model Brief {
  id           String     @id @default(cuid())
  departmentId String
  weekOf       DateTime
  status       String
  content      Json
  createdAt    DateTime   @default(now())
  department   Department @relation(fields: [departmentId], references: [id])
}

model Task {
  id           String     @id @default(cuid())
  departmentId String
  title        String
  description  String?
  status       String     @default("pending")
  priority     String     @default("medium")
  assignee     String?
  dueDate      DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  department   Department @relation(fields: [departmentId], references: [id])
}

model Metric {
  id           String     @id @default(cuid())
  departmentId String
  name         String
  value        Float
  target       Float?
  trend        String?
  recordedAt   DateTime   @default(now())
  department   Department @relation(fields: [departmentId], references: [id])
}

model Alert {
  id            String     @id @default(cuid())
  sourceDeptId  String
  targetDeptIds String[]
  type          String
  severity      String
  title         String
  description   String
  resolved      Boolean    @default(false)
  createdAt     DateTime   @default(now())
  resolvedAt    DateTime?
  sourceDept    Department @relation(fields: [sourceDeptId], references: [id])
}

model Email {
  id               String   @id @default(cuid())
  week             Int
  sequence         Int
  phase            String
  subject          String
  preview          String
  body             String
  status           String   @default("pending")
  segment          String?
  complianceStatus String   @default("not_reviewed")
  mailchimpId      String?
  approvedAt       String?
  publishedAt      String?
  metrics          Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  scheduledDate    String?
  scheduledSegment String?
  delayDays        Int?
  delayHours       Int?
  flow             String   @default("launch")
}

model Content {
  id           String    @id @default(cuid())
  type         String
  platform     String
  sourceType   String
  sourceRef    String?
  title        String
  body         String
  status       String    @default("draft")
  scheduledFor DateTime?
  publishedAt  DateTime?
  metrics      Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model NewsItem {
  id                  String   @id @default(cuid())
  title               String
  source              String
  sourceUrl           String?
  brief               String
  tag                 String
  isViral             Boolean  @default(false)
  viralReason         String?
  summary             String
  fullArticle         String
  agentRecommendation String
  coverageAngle       String
  timestamp           String
  povRecording        String?
  povTranscript       String?
  generatedContent    Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model ResearchArticle {
  id               String   @id @default(cuid())
  title            String
  journal          String
  authors          String
  doi              String?
  brief            String
  relevanceScore   Float
  fillsGap         Boolean  @default(false)
  gapDescription   String?
  summary          Json
  fullAbstract     String
  timestamp        String
  povRecording     String?
  povTranscript    String?
  generatedContent Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model RedditPost {
  id                  String   @id @default(cuid())
  subreddit           String
  title               String
  body                String
  upvotes             Int      @default(0)
  comments            Int      @default(0)
  url                 String?
  engagementPotential String
  relevanceScore      Float
  riskLevel           String
  draftResponse       String
  status              String   @default("pending")
  timestamp           String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model CalendarEntry {
  id             String   @id @default(cuid())
  date           String
  platform       String
  title          String
  excerpt        String
  status         String   @default("draft")
  sourceType     String
  engagement     Json?
  isMultiplier   Boolean  @default(false)
  multiplierNote String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Patent {
  id                     String   @id @default(cuid())
  title                  String
  shortTitle             String?
  patentNumber           String?
  type                   String
  status                 String
  filingDate             String?
  grantDate              String?
  expirationDate         String?
  description            String
  keyClaims              Json?
  assignedAttorney       String?
  priorArtNotes          String?
  competitiveThreatLevel String?
  filingPriority         String?
  filingDeadline         String?
  deadlineReason         String?
  crossDeptConnections   Json?
  notes                  String?
  claims                 Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model ComplianceClaim {
  id                String   @id @default(cuid())
  claim             String
  category          String
  status            String
  citation          String?
  studyDetails      String?
  disclaimer        String?
  restrictionReason String?
  lastReviewed      String?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model PendingReview {
  id            String   @id @default(cuid())
  source        String
  title         String
  flagReason    String
  flagType      String
  severity      String
  content       String
  submittedAt   String
  status        String   @default("pending")
  reviewerNotes String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Investor {
  id              String    @id @default(cuid())
  name            String
  firm            String?
  tier            String
  type            String
  status          String    @default("prospect")
  checkSize       String?
  thesisAlignment String?
  notes           String?
  lastContact     DateTime?
  nextAction      String?
  nextActionDate  DateTime?
  extras          Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model POV {
  id              String   @id @default(cuid())
  topic           String
  transcript      String
  sourceType      String
  sourceId        String?
  durationSeconds Int?
  keyPositions    Json     @default("[]")
  analogies       Json     @default("[]")
  emotionalTone   String?
  relatedTopics   Json     @default("[]")
  createdAt       DateTime @default(now())
}

model Capture {
  id         String   @id @default(cuid())
  type       String
  content    String
  summary    String?
  department String
  fileName   String?
  fileSize   Int?
  createdAt  DateTime @default(now())
}

model PatentClaim {
  id              String   @id @default(cuid())
  claimNumber     Int
  claimText       String
  parentPatentId  String?
  parentPatentRef String?
  valueTier       String   @default("MEDIUM")
  estimatedValue  Int?
  rationale       String?
  status          String   @default("not_drafted")
  priority        Boolean  @default(false)
  archived        Boolean  @default(false)
  category        String?
  urgency         String?
  priorArtRisk    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  claimType       String   @default("independent")
  dependsOn       Int?
  followOnNote    String?
}

model Rejection {
  id                 String   @id @default(cuid())
  recommendationId   String
  recommendationType String
  reasonCategory     String
  reasonText         String?
  userId             String   @default("kirsten")
  createdAt          DateTime @default(now())
}

model ImageFeedback {
  id          String   @id @default(cuid())
  platform    String
  contentType String
  topic       String
  prompt      String
  feedback    String
  customNote  String?
  wasApproved Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model ContentQueue {
  id           String    @id @default(cuid())
  platform     String
  title        String
  body         String
  imageData    String?
  imagePrompt  String?
  hashtags     Json?
  scheduledFor DateTime?
  status       String    @default("queued")
  postedAt     DateTime?
  postUrl      String?
  error        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model ChatLog {
  id          String   @id @default(cuid())
  contextType String
  contextId   String?
  role        String
  message     String
  createdAt   DateTime @default(now())
  sessionId   String
}

model PatentDraft {
  id           String   @id @default(cuid())
  claimId      String
  sessionId    String
  title        String?
  sections     Json?
  phase        String   @default("discovery")
  messageCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model DepartmentData {
  id         String   @id @default(cuid())
  department String
  key        String
  value      Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([department, key])
}

model Experience {
  id            String    @id @default(cuid())
  name          String    @unique
  slug          String    @unique
  tagline       String
  accentColor   String
  status        String    @default("not_started")
  description   String?
  targetPersona String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  features      Feature[]
}

model Feature {
  id              String     @id @default(cuid())
  experienceId    String
  name            String
  description     String?
  userStory       String?
  priority        String     @default("should_have")
  complexity      String     @default("medium")
  status          String     @default("idea")
  careTeamMembers Json?
  uxSpec          String?
  generatedCode   String?
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  experience      Experience @relation(fields: [experienceId], references: [id])
}

model EarlyAccessSignup {
  id              String   @id @default(cuid())
  email           String   @unique
  firstName       String?
  quizAnswers     Json
  score           Int
  scoreBreakdown  Json?
  tier            String   @default("early_access")
  referralCode    String?  @unique
  referredBy      String?
  referralCount   Int      @default(0)
  mailchimpStatus String   @default("pending")
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model QuizResponse {
  id          String   @id @default(cuid())
  email       String
  name        String?
  answers     Json
  products    Json
  cartUrl     String?
  kaiMessage  String?
  medical     String?
  medications String?
  otherNotes  String?
  topConcern  String?
  ageRange    String?
  energy      String?
  createdAt   DateTime @default(now())
}

model FoundingMember {
  id               String   @id @default(cuid())
  email            String   @unique
  firstName        String?
  signupId         String?
  spotNumber       Int
  status           String   @default("active")
  monthlyRate      Int      @default(900)
  stripeCustomerId String?
  stripeSubId      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model KaiChatLog {
  id          String   @id @default(cuid())
  email       String?
  name        String?
  isTest      Boolean  @default(false)
  userMessage String
  kaiResponse String
  concerns    String[]
  supplements String[]
  sessionId   String?
  createdAt   DateTime @default(now())
}

model ResultsPageView {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
}

model ResearchPaper {
  id                 String   @id @default(cuid())
  number             Int
  title              String
  leadAuthor         String   @default("Kirsten Karchmer")
  status             String   @default("not_started")
  targetJournal      String?
  submissionDeadline String?
  irbStatus          String   @default("n/a")
  notes              String?  @db.Text
  googleDocLink      String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ResearchDataAsset {
  id                   String   @id @default(cuid())
  name                 String
  source               String
  sampleSize           Int?
  timePeriod           String?
  irbStatus            String   @default("unknown")
  location             String?
  availableForResearch Boolean  @default(false)
  notes                String?  @db.Text
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model AcademicPartner {
  id            String   @id @default(cuid())
  name          String
  institution   String
  department    String?
  relationship  String?
  papers        String?
  contactStatus String   @default("not_contacted")
  email         String?
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model IrbProtocol {
  id             String   @id @default(cuid())
  protocolTitle  String
  institution    String?
  submissionDate String?
  status         String   @default("not_submitted")
  approvalDate   String?
  expiryDate     String?
  notes          String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model LiteratureEntry {
  id           String   @id @default(cuid())
  title        String
  authors      String?
  journal      String?
  year         Int?
  doi          String?
  abstract     String?  @db.Text
  relevanceTag String?
  notes        String?  @db.Text
  paperNumber  Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model SiteConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model KaiSession {
  id        String   @id @default(cuid())
  email     String   @unique
  messages  Json     // array of { role, content }
  gathered  Json?    // topics already gathered
  mode      String   @default("free")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model RingDataPoint {
  id          String   @id @default(cuid())
  email       String
  date        String   // YYYY-MM-DD
  temperature Float?
  hrv         Float?
  spo2        Float?
  sleepHours  Float?
  sleepScore  Float?
  steps       Int?
  stress      Float?
  raw         Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([email, date])
  @@index([email])
}

model KaiExperiment {
  id             String   @id @default(cuid())
  name           String
  hypothesis     String
  change         String
  status         String   @default("active")
  startDate      String
  endDate        String?
  baselineMetric String
  resultMetric   String?
  result         String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model KaiDailyLog {
  id              String   @id @default(cuid())
  date            String   @unique
  landingViews    Int      @default(0)
  chatsStarted    Int      @default(0)
  emailsCaptured  Int      @default(0)
  packsBuilt      Int      @default(0)
  cartClicks      Int      @default(0)
  purchases       Int      @default(0)
  revenue         Float    @default(0)
  subscribers     Int      @default(0)
  insights        String?
  recommendations String?
  topConcerns     String?
  newUsers        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
