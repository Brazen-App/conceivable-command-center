generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Agent System
// ============================================================

model Agent {
  id          String   @id @default(uuid())
  division    String   // executive-coach, marketing, legal, scientific-research, content-engine
  name        String
  description String
  systemPrompt String  @db.Text
  status      String   @default("idle") // idle, working, error, disabled
  capabilities String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages    AgentMessage[]
}

model AgentMessage {
  id        String   @id @default(uuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  role      String   // user, assistant, system
  content   String   @db.Text
  createdAt DateTime @default(now())
}

// ============================================================
// Content Engine — Morning Brief
// ============================================================

model MorningBrief {
  id          String   @id @default(uuid())
  date        DateTime @db.Date
  generatedAt DateTime @default(now())
  status      String   @default("generated") // generated, reviewed, actioned

  stories     BriefStory[]

  @@unique([date])
}

model BriefStory {
  id             String   @id @default(uuid())
  briefId        String
  brief          MorningBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)
  title          String
  summary        String   @db.Text
  sourceUrl      String
  sourcePlatform String
  relevanceScore Float    @default(0)
  viralityScore  Float    @default(0)
  topics         String[]
  publishedAt    DateTime?
  status         String   @default("pending") // pending, reviewed, selected, dismissed

  contentBatches ContentBatch[]
}

// ============================================================
// Content Engine — Content Creation
// ============================================================

model ContentBatch {
  id            String   @id @default(uuid())
  topic         String
  founderAngle  String   @db.Text
  sourceStoryId String?
  sourceStory   BriefStory? @relation(fields: [sourceStoryId], references: [id])
  status        String   @default("generating") // generating, in-review, approved, published
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  pieces        ContentPiece[]
}

model ContentPiece {
  id          String   @id @default(uuid())
  batchId     String
  batch       ContentBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  platform    String   // linkedin, instagram-post, instagram-carousel, pinterest, tiktok, youtube, blog
  title       String
  body        String   @db.Text
  imagePrompt String?  @db.Text
  imageUrl    String?
  hashtags    String[]
  status      String   @default("draft") // draft, in-review, approved, published, rejected
  createdAt   DateTime @default(now())
  publishedAt DateTime?
}

// ============================================================
// Content Engine — Viral Analyzer
// ============================================================

model ViralInsight {
  id                String   @id @default(uuid())
  sourceUrl         String
  platform          String
  hook              String   @db.Text
  format            String
  emotionalTriggers String[]
  engagementLikes   Int?
  engagementShares  Int?
  engagementComments Int?
  engagementViews   Int?
  rewrittenContent  String   @db.Text
  analyzedAt        DateTime @default(now())
}

// ============================================================
// Training & Voice Layer
// ============================================================

model TrainingDocument {
  id          String   @id @default(uuid())
  name        String
  type        String   // book, video-transcript, brand-guidelines, script, article, other
  filePath    String
  fileSize    Int
  mimeType    String
  chunkCount  Int      @default(0)
  status      String   @default("uploading") // uploading, processing, indexed, error
  uploadedAt  DateTime @default(now())
  processedAt DateTime?

  chunks      DocumentChunk[]
}

model DocumentChunk {
  id         String   @id @default(uuid())
  documentId String
  document   TrainingDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content    String   @db.Text
  embedding  Float[]
  metadata   Json?
  chunkIndex Int
  createdAt  DateTime @default(now())
}

// ============================================================
// Notifications
// ============================================================

model Notification {
  id            String   @id @default(uuid())
  title         String
  message       String   @db.Text
  type          String   @default("info") // info, success, warning, error
  read          Boolean  @default(false)
  agentDivision String?
  createdAt     DateTime @default(now())
}
